# Roofing AI Platform — environment variable reference
# Copy values into Vercel, Fly.io secrets, or local .env.local as noted.

# --- Supabase (Vercel: Production + Preview) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (Vercel + bridge host) ---
OPENAI_API_KEY=

# --- Twilio voice + SMS (Vercel: Production + Preview) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VOICE=Polly.Joanna
TWILIO_DEFAULT_COMPANY_ID=

# --- App URLs (Vercel) ---
NEXT_PUBLIC_APP_URL=

# --- Realtime bridge: Vercel PREVIEW ONLY until private testing passes ---
# Leave REALTIME_VOICE_ENABLED unset/false on Production to keep legacy Polly fallback.
REALTIME_VOICE_ENABLED=false
REALTIME_WEBSOCKET_URL=wss://roofing-realtime-bridge.fly.dev/media
REALTIME_BRIDGE_SIGNING_SECRET=

# --- Realtime bridge host (Fly.io / Docker) — not used on Vercel ---
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# OPENAI_REALTIME_VOICE=echo
# REALTIME_MEDIA_PATH=/media
# REALTIME_BARGE_IN_ENABLED=true
# PORT=8080
# MAX_CALL_DURATION_SECONDS=900
