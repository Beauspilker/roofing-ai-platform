# Realtime bridge — set on the bridge host (Fly.io secrets or local export)
# Generate REALTIME_BRIDGE_SIGNING_SECRET: openssl rand -hex 32
# Use the SAME REALTIME_BRIDGE_SIGNING_SECRET on Vercel Preview.

OPENAI_API_KEY=
REALTIME_BRIDGE_SIGNING_SECRET=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PORT=8080
REALTIME_MEDIA_PATH=/media
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=echo
REALTIME_BARGE_IN_ENABLED=true
MAX_CALL_DURATION_SECONDS=900
