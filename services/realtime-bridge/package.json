{
  "name": "realtime-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=external --alias:@=../..",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "check": "npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "twilio": "^6.0.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.9",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
