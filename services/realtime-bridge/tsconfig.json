{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "../..",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/**/*.ts", "../../lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
